{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Streamlit App",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "module": "streamlit",
      "args": [
        "run",
        "app.py",
        "--server.headless",
        "true"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}\\.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    }
  ]
}
